<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Розширюємо СТАНДАРТНИЙ шаблон кнопок list view -->
    <t t-name="bio_budget.budgetFactReportView.Buttons" t-inherit="web.ListView.Buttons" t-inherit-mode="primary">
        <!-- primary = створюємо НОВИЙ шаблон на основі існуючого -->

        <xpath expr="//div[hasclass('o_list_buttons')]" position="after">
            <div class="d-flex align-items-center gap-2 ms-2 mt-2">
                <label class="mb-0 fw-bold">Date from:</label>
                <input type="date" class="form-control form-control-sm" style="width: auto;"
                       t-att-value="dateFilter.dateFrom"
                       t-on-change="onDateFromChanged" />
                <label class="mb-0 fw-bold">to:</label>
                <input type="date" class="form-control form-control-sm" style="width: auto;"
                       t-att-value="dateFilter.dateTo"
                       t-on-change="onDateToChanged" />
                <label class="mb-0 fw-bold">Budget:</label>
                <div class="input-group input-group-sm" style="width: auto;">
                    <input type="text" class="form-control" style="min-width: 150px;"
                           t-att-value="dateFilter.budgetName"
                           placeholder="-- All --"
                           readonly="1"
                           t-on-click="onOpenBudgetModal" />
                    <button class="btn btn-outline-secondary" type="button"
                            t-if="dateFilter.budgetId"
                            t-on-click="onClearBudget">
                        ✕
                    </button>
                    <button class="btn btn-outline-secondary" type="button"
                            t-on-click="onOpenBudgetModal">
                        ▼
                    </button>
                </div>
                <button class="btn btn-sm btn-primary"
                        t-on-click="onDateFilterApply">
                    Filter
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        t-on-click="onDateFilterClear">
                    Cancel
                </button>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('o_list_buttons')]" position="after">
            <div t-if="budgetModal.show" class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Select Budget</h5>
                            <button type="button" class="btn-close"
                                    t-on-click="onCloseBudgetModal"/>
                        </div>
                        <div class="modal-body p-0">
                            <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                                <button type="button"
                                        class="list-group-item list-group-item-action"
                                        t-on-click="() => this.onSelectBudget(0, '')">
                                    -- All --
                                </button>
                                <t t-foreach="budgetOptions.list" t-as="budget" t-key="budget.id">
                                    <button type="button"
                                            class="list-group-item list-group-item-action"
                                            t-att-class="{'active': dateFilter.budgetId === budget.id}"
                                            t-on-click="() => this.onSelectBudget(budget.id, budget.name)">
                                        <t t-esc="budget.name"/>
                                    </button>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>

    <!-- Кнопки pivot view: оригінальні + дат-фільтр -->
    <t t-name="bio_budget.budgetFactReportPivotView.Buttons" owl="1">
        <!-- Включаємо стандартні кнопки pivot -->
        <t t-call="web.PivotView.Buttons"/>
        <!-- Додаємо дат-фільтр -->
        <div class="d-flex align-items-center gap-2 ms-2 mt-2">
            <label class="mb-0 fw-bold">Date from:</label>
            <input type="date" class="form-control form-control-sm" style="width: auto;"
                   t-att-value="dateFilter.dateFrom"
                   t-on-change="onDateFromChanged" />
            <label class="mb-0 fw-bold">to:</label>
            <input type="date" class="form-control form-control-sm" style="width: auto;"
                   t-att-value="dateFilter.dateTo"
                   t-on-change="onDateToChanged" />
            <label class="mb-0 fw-bold">Budget:</label>
            <div class="input-group input-group-sm" style="width: auto;">
                <input type="text" class="form-control" style="min-width: 150px;"
                       t-att-value="dateFilter.budgetName"
                       placeholder="-- All --"
                       readonly="1"
                       t-on-click="onOpenBudgetModal" />
                <button class="btn btn-outline-secondary" type="button"
                        t-if="dateFilter.budgetId"
                        t-on-click="onClearBudget">
                    ✕
                </button>
                <button class="btn btn-outline-secondary" type="button"
                        t-on-click="onOpenBudgetModal">
                    ▼
                </button>
            </div>
            <button class="btn btn-sm btn-primary"
                    t-on-click="onDateFilterApply">
                Filter
            </button>
            <button class="btn btn-sm btn-outline-secondary"
                    t-on-click="onDateFilterClear">
                Cancel
            </button>
        </div>
        <!-- Budget selection modal -->
        <div t-if="budgetModal.show" class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Select Budget</h5>
                        <button type="button" class="btn-close"
                                t-on-click="onCloseBudgetModal"/>
                    </div>
                    <div class="modal-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                            <button type="button"
                                    class="list-group-item list-group-item-action"
                                    t-on-click="() => this.onSelectBudget(0, '')">
                                -- All --
                            </button>
                            <t t-foreach="budgetOptions.list" t-as="budget" t-key="budget.id">
                                <button type="button"
                                        class="list-group-item list-group-item-action"
                                        t-att-class="{'active': dateFilter.budgetId === budget.id}"
                                        t-on-click="() => this.onSelectBudget(budget.id, budget.name)">
                                    <t t-esc="budget.name"/>
                                </button>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>