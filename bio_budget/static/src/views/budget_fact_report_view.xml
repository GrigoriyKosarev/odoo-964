<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Розширюємо СТАНДАРТНИЙ шаблон кнопок list view -->
    <t t-name="bio_budget.budgetFactReportView.Buttons" t-inherit="web.ListView.Buttons" t-inherit-mode="primary">
        <!-- primary = створюємо НОВИЙ шаблон на основі існуючого -->

        <xpath expr="//div[hasclass('o_list_buttons')]" position="after">
            <div class="d-flex align-items-center gap-2 ms-2 mt-2">
                <label class="mb-0 fw-bold">Date from:</label>
                <input type="date" class="form-control form-control-sm" style="width: auto;"
                       t-att-value="dateFilter.dateFrom"
                       t-on-change="onDateFromChanged" />
                <label class="mb-0 fw-bold">to:</label>
                <input type="date" class="form-control form-control-sm" style="width: auto;"
                       t-att-value="dateFilter.dateTo"
                       t-on-change="onDateToChanged" />
                <label class="mb-0 fw-bold">Budget:</label>
                <div class="input-group input-group-sm" style="width: auto;">
                    <input type="text" class="form-control" style="min-width: 150px;"
                           t-att-value="dateFilter.taskName"
                           placeholder="-- All --"
                           readonly="1"
                           t-on-click="onOpenBudgetModal" />
                    <button class="btn btn-outline-secondary" type="button"
                            t-if="dateFilter.taskId"
                            t-on-click="onClearBudget">
                        ✕
                    </button>
                    <button class="btn btn-outline-secondary" type="button"
                            t-on-click="onOpenBudgetModal">
                        ▼
                    </button>
                </div>
                <button class="btn btn-sm btn-primary"
                        t-on-click="onDateFilterApply">
                    Filter
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        t-on-click="onDateFilterClear">
                    Cancel
                </button>
            </div>
        </xpath>
    </t>

    <!-- Кнопки pivot view: оригінальні + дат-фільтр -->
    <t t-name="bio_budget.budgetFactReportPivotView.Buttons" owl="1">
        <!-- Включаємо стандартні кнопки pivot -->
        <t t-call="web.PivotView.Buttons"/>
        <!-- Додаємо дат-фільтр -->
        <div class="d-flex align-items-center gap-2 ms-2 mt-2">
            <label class="mb-0 fw-bold">Date from:</label>
            <input type="date" class="form-control form-control-sm" style="width: auto;"
                   t-att-value="dateFilter.dateFrom"
                   t-on-change="onDateFromChanged" />
            <label class="mb-0 fw-bold">to:</label>
            <input type="date" class="form-control form-control-sm" style="width: auto;"
                   t-att-value="dateFilter.dateTo"
                   t-on-change="onDateToChanged" />
            <label class="mb-0 fw-bold">Budget:</label>
            <div class="input-group input-group-sm" style="width: auto;">
                <input type="text" class="form-control" style="min-width: 150px;"
                       t-att-value="dateFilter.taskName"
                       placeholder="-- All --"
                       readonly="1"
                       t-on-click="onOpenTaskModal" />
                <button class="btn btn-outline-secondary" type="button"
                        t-if="dateFilter.taskId"
                        t-on-click="onClearTask">
                    ✕
                </button>
                <button class="btn btn-outline-secondary" type="button"
                        t-on-click="onOpenTaskModal">
                    ▼
                </button>
            </div>
            <button class="btn btn-sm btn-primary"
                    t-on-click="onDateFilterApply">
                Filter
            </button>
            <button class="btn btn-sm btn-outline-secondary"
                    t-on-click="onDateFilterClear">
                Cancel
            </button>
        </div>
    </t>

</templates>