    <!-- Розширюємо шаблон кнопок pivot view -->
    <t t-name="bio_budget.budgetFactReportPivotView.Buttons" t-inherit="web.PivotView.Buttons" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_pivot_buttons')]" position="after">
            <div class="d-flex align-items-center gap-2 ms-2 mt-2">
                <label class="mb-0 fw-bold">Дата з:</label>
                <input type="date" class="form-control form-control-sm" style="width: auto;"
                       t-att-value="dateFilter.dateFrom"
