<?xml version="1.0" encoding="UTF-8"?>
<odoo>


    <record id="view_us_bio_account_analytic_account_form" model="ir.ui.view">
        <field name="name">account.analytic.account.form.inherit.us_bio_analytical_accounts_extra</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="priority">60</field>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main']" position="after">

                <group>
                    <field name="account_cluster_id" placeholder="ACCOUNT cluster"/>
                    <field name="account_business_unit_id" placeholder="ACCOUNT business unit"/>
                    <field name="account_brand_id" placeholder="ACCOUNT brand"/>
                    <field name="is_grouped_account" />
                </group>



            </xpath>
            <xpath expr="//div[@class='oe_title']//field[@name='name']"
               position="replace">
                <field name="name"
                    placeholder="e.g. Project XYZ"/>
            </xpath>

        </field>
    </record>


</odoo>
